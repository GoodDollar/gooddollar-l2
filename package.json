{
  "name": "gooddollar-l2",
  "version": "0.2.0",
  "private": true,
  "description": "GoodDollar Layer 2 — DeFi protocol for universal basic income",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoniassia/gooddollar-l2"
  },
  "workspaces": [
    "frontend",
    "sdk"
  ],
  "scripts": {
    "build:contracts": "forge build",
    "test:contracts": "forge test -vvv",
    "coverage": "forge coverage --ir-minimum --report summary",
    "build:frontend": "cd frontend && npm run build",
    "build:sdk": "cd sdk && npm run build",
    "build": "npm run build:contracts && npm run build:sdk && npm run build:frontend",
    "test": "npm run test:contracts",
    "health": "bash scripts/health-check.sh",
    "test:e2e": "cd frontend && npm run test:e2e",
    "tests:publish": "python3 scripts/publish-tests-page.py",
    "build:lane1": "bash scripts/build-lane1-backend.sh",
    "install:lane1": "bash scripts/install-lane1-backend.sh",
    "test:lane1": "bash scripts/test-lane1-backend.sh"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
