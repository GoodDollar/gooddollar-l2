kensForExactTokens\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"amountIn\",\"type\":\"uint256\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"newOwner\",\"type\":\"address\"}],\"name\":\"transferOwnership\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"Only direct (single-hop) swaps are supported. Multi-hop paths with      more than 2 tokens are not implemented.\",\"kind\":\"dev\",\"methods\":{\"registerPool(address)\":{\"details\":\"Callable only by owner. The pool's tokenA/tokenB are read from the      contract to ensure the canonical key matches the pool's own ordering.\"},\"swapExactTokensForTokens(uint256,uint256,address[],address,uint256)\":{\"params\":{\"amountIn\":\"Exact amount of tokenIn to spend.\",\"amountOutMin\":\"Minimum amount of tokenOut to receive (slippage guard).\",\"deadline\":\"Unix timestamp after which the transaction reverts.\",\"path\":\"Two-element array: [tokenIn, tokenOut].\",\"to\":\"Recipient of output tokens.\"},\"returns\":{\"amountOut\":\"  Actual amount of tokenOut received.\"}},\"swapTokensForExactTokens(uint256,uint256,address[],address,uint256)\":{\"params\":{\"amountInMax\":\"Maximum amount of tokenIn to spend (slippage guard).\",\"amountOut\":\"Exact amount of tokenOut to receive.\",\"deadline\":\"Unix timestamp after which the transaction reverts.\",\"path\":\"Two-element array: [tokenIn, tokenOut].\",\"to\":\"Recipient of output tokens.\"},\"returns\":{\"amountIn\":\"   Actual amount of tokenIn spent.\"}}},\"title\":\"GoodSwapRouter\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"getAmountIn(uint256,address,address)\":{\"notice\":\"Quote: how much tokenIn is needed to receive exactly `amountOut`?         Inverse of the GoodPool AMM formula (0.3% fee):           amountIn = ceil(amountOut * resIn * 10000 / ((resOut - amountOut) * 9970))\"},\"getAmountOut(uint256,address,address)\":{\"notice\":\"Quote: how much tokenOut for `amountIn` of tokenIn?\"},\"getPool(address,address)\":{\"notice\":\"Look up the pool for a given token pair (order-independent).\"},\"pools(bytes32)\":{\"notice\":\"Pool registry: canonical pair key \\u2192 GoodPool address.         Key is keccak256(abi.encodePacked(lowerAddr, higherAddr)).\"},\"registerPool(address)\":{\"notice\":\"Register a GoodPool for a token pair.\"},\"removePool(address,address)\":{\"notice\":\"Remove a pool from the registry.\"},\"swapExactTokensForTokens(uint256,uint256,address[],address,uint256)\":{\"notice\":\"Swap an exact input amount for as many output tokens as possible.\"},\"swapTokensForExactTokens(uint256,uint256,address[],address,uint256)\":{\"notice\":\"Receive an exact output amount by spending as few input tokens as possible.\"},\"transferOwnership(address)\":{\"notice\":\"Transfer ownership.\"}},\"notice\":\"UniV2-style router for the GoodSwap constant-product AMM.         Users approve the router (not individual pools) and call         swapExactTokensForTokens / swapTokensForExactTokens. The router         looks up the registered GoodPool for the given token pair, executes         the swap, and forwards output tokens to `to`.         Fee architecture: GoodPool collects 0.3% on input and routes 33.33%         of that fee to the UBIFeeSplitter automatically (no router action         needed). The router only handles routing and slippage enforcement.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/swap/GoodSwapRouter.sol\":\"GoodSwapRouter\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"],\"viaIR\":true},\"sources\":{\"lib/forge-std/src/interfaces/IERC20.sol\":{\"keccak256\":\"0x5945813ecc305238ca86d7a211a52f300e41173e34d39166f99758a857717dec\",\"license\":\"MIT OR Apache-2.0\",\"urls\":[\"bzz-raw://2ace7b2e42fa6f84f660987cc3020d1494ba0fe4d5