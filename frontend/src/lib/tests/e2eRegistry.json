        "token explorer renders",
        "market rows or empty state render",
        "no 404/error shell"
      ],
      "titlePattern": "Explore",
      "mustContain": [
        "Explore"
      ]
    },
    {
      "id": "pool",
      "name": "Pool",
      "route": "/pool",
