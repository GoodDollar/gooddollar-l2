{
  "version": "testnet-e2e-0.1",
  "updatedAt": "2026-05-16",
  "baseUrls": {
    "app": "https://goodswap.goodclaw.org",
    "publicPortal": "https://goodclaw.org/tests"
  },
  "playwright": {
    "config": "frontend/playwright.config.ts",
    "command": "cd frontend && SKIP_DEV_SERVER=1 BASE_URL=http://localhost:3100 npm run test:e2e",
    "report": "frontend/playwright-report/index.html"
  },
  "apps": [
    {
      "id": "swap",
      "name": "GoodSwap",
      "route": "/",
      "kind": "core",
      "owner": "GoodSwap",
      "critical": true,
      "assertions": [
        "loads swap card",
        "shows UBI funding narrative",
        "no 404/error shell"
      ],
      "titlePattern": "Trade\\. Predict\\. Invest\\. Fund",
      "mustContain": [
        "Trade",
        "UBI"
      ]
    },
    {
      "id": "explore",
      "name": "Explore",
      "route": "/explore",
      "kind": "core",
      "owner": "Explore",
      "critical": true,
