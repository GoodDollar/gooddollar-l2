# GoodDollar L2 Frontend — environment template.
# Copy to .env.local and fill in values you need. All NEXT_PUBLIC_* values
# are inlined into the client bundle at build time.

# Local subgraph / indexer the frontend reads activity & metrics from.
NEXT_PUBLIC_INDEXER_URL=http://localhost:4200

# WalletConnect / RainbowKit — OPTIONAL for mobile wallet connections.
# NEXT_PUBLIC_WC_PROJECT_ID must be a 32-char hex string from
# https://cloud.walletconnect.com. Anything else (empty, short, dashes,
# placeholders like "goodswap-dev") is treated as UNSET by wagmi.ts and
# mobile WalletConnect flows are disabled. Browser/desktop wallets
# (MetaMask extension, injected EIP-1193 providers, Coinbase extension)
# work without a project ID.
# NEXT_PUBLIC_WC_PROJECT_ID=

# Set to "1" to expose the internal "Tests" link in the mobile nav, which
# routes to /test-dashboard (the Foundry/QA dashboard). Leave UNSET in
# production — the /test-dashboard route itself stays reachable via direct
# URL either way, so dev/QA workflows are not affected.
# See .autobuilder/initiatives/0002-security-hardening/tasks/0070-remove-tests-link-from-user-navigation.md
# NEXT_PUBLIC_SHOW_DEV_NAV=
