# GoodDollar L2 Frontend Environment
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001
# WalletConnect Cloud project ID — enables mobile wallet connections
# (Rainbow, MetaMask Mobile, Trust Wallet, etc.)
# 1. Register free at https://cloud.walletconnect.com
# 2. Create a project, copy the 32-char hex ID
# 3. Paste it below (or in .env.local)
# Without this, only browser-extension wallets work.
NEXT_PUBLIC_WC_PROJECT_ID=

# Server-side TTL+single-flight cache for /api/stocks/rebalance-status.
# Collapses tab storms and many tabs into one upstream fetch per TTL
# window. `0` disables the cache so every request hits upstream
# (operator escape for debugging aggregator behavior).
STATUS_AGGREGATOR_CACHE_MS=1000

# Server-side TTL+single-flight cache for /api/oracle/status.
# The route fans out to both price-service /status/quotes and
# oracle-signer /proof; the cache bounds upstream QPS at ~1 pair fetch
# per TTL window regardless of how many tabs poll the OracleStatusBadge.
# `0` disables the cache so every request hits both upstreams
# (operator escape for debugging upstream behavior).
ORACLE_STATUS_CACHE_MS=1000
