# GoodDollar L2 Frontend Environment
NEXT_PUBLIC_INDEXER_URL=http://localhost:4200

# WalletConnect / RainbowKit — REQUIRED for mobile wallet connections
# Register your project at https://cloud.walletconnect.com and paste the projectId here.
# Without this, mobile wallets (Rainbow, MetaMask Mobile, Trust Wallet, Coinbase Mobile)
# will fail to connect and every page will log 403/400 console errors.
# NEXT_PUBLIC_WC_PROJECT_ID=your-real-project-id-here
