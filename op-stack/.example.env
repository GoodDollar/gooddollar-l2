# ============================================================
# GoodDollar L2 — OP Stack Environment Configuration (Sepolia)
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .example.env .env
#
# For local development, use Kurtosis instead (no .env needed):
#   make kurtosis-up
#
# NEVER commit .env to version control!
# ============================================================

# ----------------------------------------------------------
# L1 Configuration (Sepolia)
# ----------------------------------------------------------

L1_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
L1_BEACON_URL="https://ethereum-sepolia-beacon-api.publicnode.com"
L1_CHAIN_ID="11155111"

# ----------------------------------------------------------
# REQUIRED: Private Key for Deployment & Operations
# ----------------------------------------------------------
# Fund this with ≥2 Sepolia ETH for contract deployment + operations
# Remove the 0x prefix if present
PRIVATE_KEY="YOUR_PRIVATE_KEY_WITHOUT_0X_PREFIX"

# ----------------------------------------------------------
# GoodDollar L2 Chain Configuration
# ----------------------------------------------------------
# Chain ID 42069 — GoodDollar L2
L2_CHAIN_ID="42069"

# Human-readable chain name (used in logs/docs only)
L2_CHAIN_NAME="GoodDollar L2"

# ----------------------------------------------------------
# OPTIONAL: Networking
# ----------------------------------------------------------
# For local testing, 127.0.0.1 is fine
# For production/testnet, run: curl ifconfig.me
P2P_ADVERTISE_IP="127.0.0.1"

# ----------------------------------------------------------
# ADVANCED: Batcher Configuration
# ----------------------------------------------------------
OP_BATCHER_POLL_INTERVAL="1s"
OP_BATCHER_SUB_SAFETY_MARGIN="6"
OP_BATCHER_NUM_CONFIRMATIONS="1"
OP_BATCHER_SAFE_ABORT_NONCE_TOO_LOW_COUNT="3"

# ----------------------------------------------------------
# ADVANCED: Proposer Configuration
# ----------------------------------------------------------
OP_PROPOSER_PROPOSAL_INTERVAL="3600s"
OP_PROPOSER_GAME_TYPE="0"
OP_PROPOSER_POLL_INTERVAL="20s"

# ----------------------------------------------------------
# NOTE: Native Token
# ----------------------------------------------------------
# OP Stack uses ETH as the native gas token by default.
# GoodDollar (G$) contracts will be deployed as ERC-20s on L2
# AFTER the chain is running. See /contracts/ directory.
# Custom gas token support is on the OP Stack roadmap.
