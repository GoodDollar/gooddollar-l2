# eToro API Credential Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.

# Mode: "sandbox" (default), "demo", or "real"
# - sandbox: legacy alias for eToro's sandbox API (no real money).
# - demo:    the only mode the hedge-engine accepts for live-order paths.
#            Aliases the sandbox API but is a distinct safety label.
# - real:    live trading. Requires ETORO_REAL_CONFIRMED=true AND is
#            still rejected by hedge-engine/src/safety.ts.
ETORO_MODE=sandbox

# Sandbox credentials
ETORO_SANDBOX_KEY=your-sandbox-api-key
ETORO_SANDBOX_SECRET=your-sandbox-api-secret

# Demo credentials (only used when ETORO_MODE=demo).
# Falls back to ETORO_SANDBOX_KEY / ETORO_SANDBOX_SECRET if these are absent.
# ETORO_DEMO_KEY=your-demo-api-key
# ETORO_DEMO_SECRET=your-demo-api-secret

# Real credentials (only used when ETORO_MODE=real)
ETORO_REAL_KEY=your-real-api-key
ETORO_REAL_SECRET=your-real-api-secret

# Safety latch: must be "true" to enable real mode
# ETORO_REAL_CONFIRMED=true

# Optional: override base URL (for testing against a proxy)
# ETORO_BASE_URL=https://api.etoro.com/sapi

# ───────────────────────────────────────────────────────────────────────────
# Lane 6 — Demo notional caps (enforced inside TradingModule)
# Defaults are intentionally tight — env can raise OR lower them, but cannot
# disable the cap (set to 0 fails closed). Cap rejections never hit eToro.
#
# Per-order notional cap in USD. Default 100.
# MAX_DEMO_ORDER_NOTIONAL_USD=100
#
# Rolling daily notional cap in USD (UTC midnight reset). Default 1000.
# MAX_DAILY_DEMO_NOTIONAL_USD=1000
#
# Lane 6 source-level fence: REAL_TRADING_ENABLED is a HARDCODED constant
# (literal `false`) in backend/etoro-client/src/safety.ts. There is no env
# variable to flip it — you must edit source and recompile. This is by design.
