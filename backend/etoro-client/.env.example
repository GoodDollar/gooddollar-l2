# eToro Client SDK — Lane 1 environment contract
# Copy to .env and fill in your values. NEVER commit .env to git.

# Mode selector. One of:
#   mock          — zero-network deterministic fake (default if unset)
#   demo-readonly — live demo URLs, market-data only
#   demo-trading  — live demo URLs, market-data + capped demo trading
#   real-disabled — live demo URLs, trading hard-disabled by source-level fence
ETORO_MODE=mock

# Demo credentials (required for demo-readonly, demo-trading, real-disabled).
# Not consulted in mock mode.
# ETORO_DEMO_KEY=your-demo-api-key
# ETORO_DEMO_SECRET=your-demo-api-secret

# Optional demo URL overrides (defaults: api.etoro.com/sapi/demo).
# ETORO_DEMO_BASE_URL=https://api.etoro.com/sapi/demo
# ETORO_DEMO_WS_URL=wss://streamer.etoro.com/sapi/demo

# Demo trading caps (only enforced in demo-trading mode).
# Defaults: per-order 1000 USD, daily cumulative 10000 USD.
# MAX_DEMO_ORDER_NOTIONAL_USD=1000
# MAX_DAILY_DEMO_NOTIONAL_USD=10000

# Optional: override the eToro instrument IDs for the lane symbols.
# Pass a JSON object keyed by lane symbol. Unknown symbols are dropped.
# ETORO_INSTRUMENT_OVERRIDES={"BTC":{"etoroInstrumentId":"INST-100100"},"AAPL":{"etoroInstrumentId":"INST-1001"}}

# Real-account credentials are deliberately NOT supported by this lane.
# The source-level fence (REAL_TRADING_ENABLED=false in auth.ts) means no
# combination of env vars can enable real-account trading.
