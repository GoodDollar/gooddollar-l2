# GoodChain arb bot
GOODCHAIN_RPC_URL=https://rpc.goodclaw.org
GOODCHAIN_CHAIN_ID=42069
GOODCHAIN_STATUS_URL=https://goodswap.goodclaw.org/api/status

# Leave empty for dry-run only. Use a dedicated hot wallet with tiny limits.
PRIVATE_KEY=

# Safety defaults
DRY_RUN=true
POLL_INTERVAL_MS=10000
MAX_TRADE_USD=10
MIN_PROFIT_USD=0.05
MIN_PROFIT_BPS=30
MAX_SLIPPAGE_BPS=50
GAS_BUFFER_BPS=120

# Optional JSON file defining markets/contracts discovered from GoodSwap APIs/docs
MARKETS_FILE=./markets.example.json
