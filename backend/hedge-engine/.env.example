# Hedge-engine configuration (lane 5 — demo-only hedging proof).
# Copy to .env and fill in your values. NEVER commit .env to git.

# --- Chain ---
RPC_URL=http://localhost:8545
RISK_ENGINE_ADDRESS=                  # 0x... address of UnifiedRiskEngine

# --- Symbols & cadence ---
HEDGE_SYMBOLS=AAPL,TSLA,NVDA,MSFT,META,AMZN,GOOGL,SPY,QQQ
HEDGE_POLL_INTERVAL_MS=30000
HEDGE_DELTA_THRESHOLD_USD=5000
HEDGE_DELTA_THRESHOLD_PCT=2

# --- Safety fence (see safety.ts) ---
# Hedge-engine only opens demo eToro orders when ETORO_MODE=demo.
# `sandbox` or `real` will trip the fence at boot and the engine
# stays in degraded mode (health server still reachable).
ETORO_MODE=demo

# Set HEDGE_DRY_RUN=false to actually open demo orders. Defaults to true.
HEDGE_DRY_RUN=true

# --- Demo trading caps (lane 5 — clamped to spec ceilings) ---
MAX_DEMO_ORDER_NOTIONAL_USD=100       # hard ceiling: $100 per order
MAX_DAILY_DEMO_NOTIONAL_USD=300       # hard ceiling: $300/day, UTC reset
HEDGE_MAX_ORDERS_PER_CYCLE=3
HEDGE_MAX_ORDERS_PER_DAY=10

# --- Kill switch ---
# When this file exists, the engine stops sending orders within one tick.
# Touch the file to halt; delete it to resume.
HEDGE_KILL_SWITCH_FILE=.hedge-kill-switch

# --- Instrument map ---
# Optional comma-separated override: SYMBOL:INSTRUMENT_ID,...
# Missing symbols fall through to client.marketData.getInstrument(symbol).
HEDGE_INSTRUMENT_MAP=

# --- Health server ---
HEDGE_ENGINE_PORT=9106
