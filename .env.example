# ============================================================
# GoodDollar L2 — local environment
# ============================================================
# `cp .env.example .env` and edit only the lines you need.
# All Lane-1 entries below are commented (`# KEY=`); leaving them
# unset puts the SDK in safe `mock` mode by default. Defaults and
# the full env contract live in:
#   - docs/ETORO_GOODCHAIN_ADAPTER.md  (Lane 1 env contract)
#   - backend/README.md                (PM2 keepers)

# ----- Chain / on-chain submission -----
# GoodDollar L2 local deployer key.
# Use an Anvil throwaway key locally. Never commit a funded/private production key.
PRIVATE_KEY=
# RPC_URL=                  # JSON-RPC URL for oracle-signer / hedge-engine. Default: http://localhost:8545
# L2_RPC_URL=               # oracle-signer alias for RPC_URL.
# RISK_ENGINE_ADDRESS=      # On-chain risk engine; unset = hedge-engine read-only / health-only.
# ORACLE_SIGNER_KEY=        # Signer private key for oracle-signer; unset = signer health-only.

# ----- Lane 1 — eToro SDK (mock | demo-readonly | demo-trading | real-disabled) -----
# Demo-only by source-level fence (REAL_TRADING_ENABLED const in
# backend/etoro-client/src/auth.ts). No real-money path exists.
# ETORO_MODE=mock             # Default = mock. Throws InvalidModeError for typos.
# ETORO_DEMO_KEY=             # Demo API key (required for demo-readonly / demo-trading / real-disabled).
# ETORO_DEMO_SECRET=          # Demo API secret. Reserved for signed-trade follow-ups.
# ETORO_DEMO_USER_KEY=        # Demo user identifier (sent as x-user-key).
# ETORO_USER_KEY=             # Real-account user identifier; only read in real-disabled mode.
# ETORO_DEMO_BASE_URL=        # REST base URL. Default: https://public-api.etoro.com/api/v1
# ETORO_DEMO_WS_URL=          # WebSocket URL. Default: wss://streamer.etoro.com/sapi/demo

# ----- Lane 1 — demo trading safety caps (demo-trading only) -----
# MAX_DEMO_ORDER_NOTIONAL_USD=1000   # Per-order USD cap. 0 = "no orders allowed".
# MAX_DAILY_DEMO_NOTIONAL_USD=10000  # Cumulative daily USD cap (UTC bucket).

# ----- Lane 1 — hedge-engine -----
# HEDGE_TRADING_ENABLED=false        # Must be 'true' AND ETORO_MODE=demo-trading for orders to land.
# HEDGE_SYMBOLS=                     # Comma-separated subset of INSTRUMENT_MAP symbols. Default: DEFAULT_LANE_SYMBOLS.
# HEDGE_INSTRUMENT_MAP=              # Operator override: AAPL:INST-1001,BTC:INST-100100
# HEDGE_DELTA_THRESHOLD_USD=5000     # Re-hedge trigger by USD delta.
# HEDGE_DELTA_THRESHOLD_PCT=2        # Re-hedge trigger by % delta.
# HEDGE_POLL_INTERVAL_MS=30000       # Reconcile loop cadence.
# HEDGE_DRY_RUN=true                 # Default = true; set 'false' to allow capped demo orders.
# HEDGE_ENGINE_PORT=9106             # Health/RPC port; HEALTH_PORT also accepted.
# ORACLE_SIGNER_PORT=9107            # oracle-signer health port.
# PRICE_SERVICE_URL=                 # Default: ws://localhost:4001 (oracle-signer source).
# PRICE_SERVICE_STRICT_MODE=         # 'true' = fail boot on missing demo creds; default tolerates it.
# ORACLE_SYMBOLS=                    # Comma-separated symbols for price-service / oracle-signer.

# ----- Lane 1 — instrument overrides + audit log -----
# ETORO_INSTRUMENT_OVERRIDES={"BTC":{"etoroInstrumentId":"INST-100100"}}
# ETORO_AUDIT_LOG_PATH=              # Default: <cwd>/.etoro-audit/<mode>.log

# ----- Lane 1 — demo-proof script (backend/hedge-engine/scripts/demo-proof.ts) -----
# PROOF_SYMBOL=AAPL                  # Symbol to hedge in the proof run.
# PROOF_AMOUNT_USD=25                # Hard-clamped to MAX_DEMO_ORDER_NOTIONAL_USD.
# PROOF_INSTRUMENT_ID=INST-1001      # Pinned eToro instrument ID for the proof run.

# ----- Lane 1 — live-integration tests (opt-in) -----
# ETORO_LIVE_TESTS=1                 # Enables backend/etoro-client live-integration suite.
