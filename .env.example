# Lane-7 Internal Testnet — operator env bootstrap.
# Source of truth: docs/testnet/INTERNAL-TESTNET-RUNBOOK.md
#                  ("One-time setup" section)
# Validated by:    scripts/testnet/internal-smoke.sh
#                  (loader at scripts/testnet/lib/load-lane7-env.sh)
#
# Bootstrap: `cp .env.example .env`, then fill in PRIVATE_KEY and any
# keys your coordinator provisions (ORACLE_SIGNER_KEY,
# RISK_ENGINE_ADDRESS). Do NOT commit .env — the repo .gitignore
# already excludes it.

# --- Secrets (NEVER commit values) ----------------------------
# Local deployer key for the op-stack devnet. Use an Anvil throwaway
# key locally. Never commit a funded or production private key.
PRIVATE_KEY=
# Oracle-signer testnet key — leave blank until the lane-7
# coordinator provisions one. The smoke WARNs when blank
# (health-only mode), but does NOT BLOCKER.
ORACLE_SIGNER_KEY=
# Hedge-engine risk-engine contract address — leave blank until
# `HEDGE_DRY_RUN=false` is approved by the coordinator.
RISK_ENGINE_ADDRESS=

# eToro demo/public API credentials. Leave blank for ETORO_MODE=mock.
# Required only when ETORO_MODE=demo-readonly, demo-trading, or real-disabled.
ETORO_DEMO_KEY=
ETORO_DEMO_SECRET=
ETORO_DEMO_USER_KEY=
ETORO_USER_KEY=
ETORO_DEMO_BASE_URL=https://public-api.etoro.com/api/v1
ETORO_DEMO_WS_URL=wss://streamer.etoro.com/sapi/demo

# --- Lane-local PM2 ports (49xxx range — must NOT collide -----
#     with production reserved 4000/4001/9106/9107/9200; see
#     runbook lines 139-150).
PRICE_SERVICE_PORT=49300
PRICE_SERVICE_WS_PORT=49301
ORACLE_SIGNER_PORT=49107
HEDGE_ENGINE_PORT=49106
STATUS_AGGREGATOR_PORT=49200

# --- Lane-local devnet RPC (anvil) ----------------------------
# `L2_RPC_URL` is consumed by foundry / deployer scripts.
# `LANE7_RPC` drives the smoke's on-chain freshness probe.
# Leave LANE7_RPC commented to skip on-chain freshness with a WARN
# (the spec's "explicitly blocked" branch).
L2_RPC_URL=http://localhost:8545
LANE7_RPC=http://localhost:8545

# --- Hard safety fences (DO NOT change without explicit -------
#     coordinator approval; the smoke fails RED on any other
#     value for REAL_TRADING_ENABLED / ETORO_MODE).
REAL_TRADING_ENABLED=false
ETORO_MODE=mock
HEDGE_DRY_RUN=true

# --- Optional smoke tunings (defaults are sensible) -----------
# Uncomment to override the smoke's hardcoded fallbacks.
# STALENESS_THRESHOLD_S=600
# MIN_FRESH_QUOTES=1
# QUOTE_MAX_AGE_S=600
# STOCK_ORACLE_V2_ADDRESS=  # auto-resolved from op-stack/addresses.json
