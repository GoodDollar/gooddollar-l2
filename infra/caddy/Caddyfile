goodagent.goodclaw.org {
	@tori path /tori /tori/*
	reverse_proxy @tori 127.0.0.1:3109

	reverse_proxy 127.0.0.1:3099
}

goodclaw.org {
	tls /etc/letsencrypt/live/explorer.goodclaw.org/fullchain.pem /etc/letsencrypt/live/explorer.goodclaw.org/privkey.pem
	root * /home/goodclaw/goodclaw-landing
	file_server
}

api.goodclaw.org {
	tls /etc/letsencrypt/live/explorer.goodclaw.org/fullchain.pem /etc/letsencrypt/live/explorer.goodclaw.org/privkey.pem
	header Content-Type application/json
	respond `{"status":"ok","service":"GoodDollar L2 API","chainId":42069,"rpc":"https://rpc.goodclaw.org","revivedAt":"2026-05-13T19:59:00Z"}` 200
}

